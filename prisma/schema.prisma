// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  password          String?
  image             String?
  phone             String?
  role              String    @default("customer") // customer, admin, support
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  accounts          Account[]
  sessions          Session[]
  cart              CartItem[]
  orders            Order[]
  addresses         Address[]
  reviews           Review[]
  wishlistItems     WishlistItem[]
  matchAccesses     MatchAccess[]
  orderReturns      OrderReturn[]
  preferredTeams    UserPreferredTeam[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AdminInvite {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique
  role        String    @default("admin")  // admin, support
  invitedById String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  imageUrl    String?
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String   @db.Text
  shortDescription String? @db.Text
  price         Float
  compareAtPrice Float?
  printable     Boolean  @default(false)  // Personalization (name/number) available
  printingCost  Float    @default(0)      // Additional cost for printing
  sku           String?  @unique
  category      String
  tags          String[]
  images        String[]
  sizes         String[]
  colors        String[]
  stock         Int      @default(0)
  lowStockThreshold Int  @default(10)
  weight        Float?
  dimensions    Json?    // {length, width, height}
  featured      Boolean  @default(false)
  active        Boolean  @default(true)
  onSale        Boolean  @default(false)
  newArrival    Boolean  @default(false)
  bestSeller    Boolean  @default(false)
  freeShippingEligible Boolean @default(true) // If false, product does not qualify for free shipping threshold
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cartItems     CartItem[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      // 1-5
  title     String?
  comment   String?  @db.Text
  images    String[] @default([])
  verified  Boolean  @default(false)
  helpful   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Coupon {
  id                 String   @id @default(cuid())
  code               String   @unique
  type               String   // percentage, fixed, free_shipping
  value              Float    @default(0)  // % off, $ off, or 0 for free_shipping
  minPurchase        Float?   @default(0)
  maxDiscount        Float?
  usageLimit         Int?
  usageLimitPerUser  Int?     // Max uses per customer (null = unlimited)
  usedCount          Int      @default(0)
  validFrom          DateTime
  validUntil         DateTime
  freeShipping       Boolean  @default(false)  // Free shipping discount
  description        String?  @db.Text  // Admin note
  active             Boolean  @default(true)
  showOnPromoBar     Boolean  @default(false)  // If true, shown in top promo bar on landing
  promoBarLabel      String?  @db.Text         // Custom text for promo bar (e.g. "Free shipping on orders over $50")
  promoBarSortOrder  Int      @default(0)      // Lower = first in promo bar
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  orders             Order[]
}

model ShippingMethod {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  type        String   // flat, weight, price
  cost        Float
  freeThreshold Float? // Free shipping above this amount
  estimatedDays Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CartItem {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  quantity     Int      @default(1)
  size         String?
  color        String?
  printedName   String   @default("")  // Custom name on back ("" = no printing)
  printedNumber String   @default("")  // Custom number on back
  printingCost Float    @default(0) // Cost for personalization
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, size, color, printedName, printedNumber])
  @@index([userId])
}

model MpesaStkRequest {
  id                 String   @id @default(cuid())
  checkoutRequestId  String   @unique
  orderNumber        String
  amount             Float
  phone              String?
  status             String   @default("pending")  // pending, completed, failed
  mpesaReceiptNumber String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([checkoutRequestId])
  @@index([orderNumber])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  orderNumber     String      @unique
  status          String      @default("pending") // pending, processing, shipped, delivered, cancelled
  paymentStatus   String      @default("pending") // pending, paid, failed, refunded
  paymentMethod   String?
  subtotal        Float
  discount        Float       @default(0)
  tax             Float       @default(0)
  shipping        Float       @default(0)
  total           Float
  shippingAddress Json
  billingAddress  Json?
  shippingMethod  String?
  trackingNumber  String?
  trackingCarrier String?   // DHL, FedEx, UPS, etc. for tracking links
  shippedAt       DateTime? // When order was shipped
  notes           String?   @db.Text
  paypalCaptureId String?   // For PayPal refunds
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  returns         OrderReturn[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  price         Float
  size          String?
  color         String?
  printedName   String?
  printedNumber String?
  printingCost  Float    @default(0)
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model StreamingPlan {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  price       Float
  interval    String   // month, 6months, year
  features    String[] // list of features
  popular     Boolean  @default(false)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeaturedMatch {
  id        String   @id  // singleton: use "default"
  imageUrl  String?
  videoUrl  String?  // YouTube link
  title     String?
  updatedAt DateTime @updatedAt
}

model Match {
  id          String    @id @default(cuid())
  homeTeam    String
  awayTeam    String
  matchDate   DateTime
  venue       String?
  status      String    @default("scheduled") // scheduled, live, finished
  accessPrice Float     @default(0)  // price to buy match access
  videoUrl    String?   // stream URL (shown after purchase)
  imageUrl    String?   // hero image when featured on landing page
  featured    Boolean   @default(false)  // show on landing page hero
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  accesses    MatchAccess[]
}

model MatchAccess {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  amount    Float
  paidAt    DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}

model Team {
  id               String             @id @default(cuid())
  name             String
  slug             String             @unique
  logoUrl          String?
  sportType        String             // football, basketball, hockey, etc.
  description      String?            @db.Text
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  preferredByUsers UserPreferredTeam[]
}

model UserPreferredTeam {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
}

model News {
  id          String   @id @default(cuid())
  title       String
  excerpt     String?  @db.Text
  content     String   @db.Text
  teams       String[] // team names for badge tags
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SeoSettings {
  id              String   @id  // singleton: use "default"
  siteName        String?
  tagline         String?  // slogan for landing page title: "Site Name | Tagline"
  defaultMetaDesc String?  @map("default_meta_desc")
  metaKeywords    String?  @map("meta_keywords") @db.Text
  ogImage         String?  @map("og_image")
  googleTagId     String?  @map("google_tag_id")
  facebookPixelId String?  @map("facebook_pixel_id")
  twitterHandle   String?  @map("twitter_handle")
  canonicalBase   String?  @map("canonical_base")
  updatedAt       DateTime @updatedAt
}

model PaymentSettings {
  id            String   @id  // singleton: use "default"
  bankName      String?
  accountName   String?
  accountNumber String?
  branchName    String?
  swiftCode     String?
  bankCode      String?
  instructions  String?  @db.Text
  updatedAt     DateTime @updatedAt
}

model CurrencySettings {
  id                    String   @id  // singleton: use "default"
  baseCurrency          String?  @default("KES")  // e.g. KES (DB/store currency)
  defaultDisplayCurrency String? @default("KES")  // default for frontend
  exchangeRateApiUrl    String?  @db.Text  // e.g. https://api.exchangerate-api.com/v4/latest
  exchangeRateApiKey    String?  // optional API key
  exchangeRateFallback  Float?   // fallback rate when API fails (KES→USD e.g. 0.0077)
  updatedAt             DateTime @updatedAt
}

model TaxSettings {
  id        String   @id  // singleton: use "default"
  enabled   Boolean  @default(false)
  name      String   @default("VAT") // Display name e.g. VAT, Sales Tax
  rate      Float    @default(0.16)  // 16% VAT by default
  country   String?           // Optional: only apply when shipping country matches (e.g. "Kenya")
  updatedAt DateTime @updatedAt
}

model MaintenanceSettings {
  id             String    @id  // singleton: use "default"
  enabled        Boolean   @default(false)
  estimatedEndAt DateTime? // For countdown display
  message        String?   @db.Text  // Optional custom message
  updatedAt      DateTime  @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String   @db.Text
  answer    String   @db.Text
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique  // privacy-policy, about-us, terms-of-service
  title     String
  content   String   @db.Text  // HTML from WYSIWYG
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  createdAt DateTime @default(now())
}

model OrderReturn {
  id          String   @id @default(cuid())
  orderId     String
  userId      String
  reason      String   @db.Text
  status      String   @default("pending")  // pending, approved, rejected, completed
  notes       String?  @db.Text
  requestedAt DateTime @default(now())
  resolvedAt  DateTime?
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([orderId])  // one return per order
  @@index([userId])
  @@index([orderId])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  type        String   // shipping, billing
  firstName   String
  lastName    String
  company     String?
  address1    String
  address2    String?
  city        String
  state       String?
  postalCode  String
  country     String
  phone       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
